# ============ Telegram ============
# @BotFather dan olinadi: /newbot -> token
TELEGRAM_BOT_TOKEN=
# Whitelist — faqat shu chat ID'lar botdan foydalana oladi (vergul bilan).
# ID'ni bilish: botga /start yozing, u ruxsatsizlarga o'z ID'sini ko'rsatadi.
TELEGRAM_ALLOWED_CHAT_IDS=
# Admin (bitta chat ID) — statistika, API holati va "hozir yuborish" tugmalari
TELEGRAM_ADMIN_CHAT_ID=

# ============ LLM ============
# Tanlash: anthropic | openai | gemini
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# Ixtiyoriy — model o'zgartirish:
# ANTHROPIC_MODEL=claude-opus-4-8
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-2.0-flash

# ============ Database ============
# h2 (default): hech narsa o'rnatish shart emas, data ./data papkada saqlanadi
# postgres: quyidagi DB_* sozlamalar ishlaydi
DB_MODE=h2

# DB_MODE=postgres bo'lganda DB_HOST variantlari:
#   db                    -> compose o'zi postgres ko'taradi (--profile postgres bilan up qiling)
#   <konteyner-nomi>      -> mavjud docker konteyner (docker-compose.external-db.yml bilan)
#   host.docker.internal  -> kompyuterda o'rnatilgan postgres
DB_HOST=db
DB_PORT=5432
DB_NAME=news_agent
DB_USERNAME=postgres
DB_PASSWORD=postgres
# 2b rejim uchun: tashqi postgres konteyner tarmog'i
# EXTERNAL_NETWORK=

# ============ App ============
TZ=Asia/Tashkent
